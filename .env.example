# Configurações de Email para Notificações
EMAIL_HOST_USER=seu_email@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_app
NOTIFICATION_EMAIL=email@destinatario.com

# Outras variáveis de ambiente existentes...
# ENV_PUSHER_APP_ID=""
# ENV_PUSHER_KEY=""
# ENV_PUSHER_SECRET=""
# ENV_PUSHER_CLUSTER=""

# OAuth Social Login
SOCIAL_AUTH_STATE_EXPIRATION_MINUTES=10
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_DISCORD_CLIENT_ID=
SOCIAL_DISCORD_CLIENT_SECRET=
SOCIAL_GITHUB_CLIENT_ID=
SOCIAL_GITHUB_CLIENT_SECRET=
SOCIAL_FACEBOOK_CLIENT_ID=
SOCIAL_FACEBOOK_CLIENT_SECRET=
SOCIAL_MICROSOFT_CLIENT_ID=
SOCIAL_MICROSOFT_CLIENT_SECRET=

# AI / LLM
AI_DEFAULT_TIMEOUT_SECONDS=20
AI_DEFAULT_MAX_RETRIES=1
AI_ENABLE_FALLBACK=true
AI_ASSIST_ENABLED=true
KAWORI_ENVIRONMENT=development
AI_PROMPT_ENVIRONMENT=development
AI_PROMPT_DB_OVERRIDE_ENABLED=false
AI_PROMPT_OVERRIDE_CACHE_TTL_SECONDS=60
AI_IMPORT_SUGGESTION_MAX_ITEMS=20
AI_IMPORT_SUGGESTION_MAX_PER_REQUEST=12
AI_IMPORT_SUGGESTION_DAILY_PER_USER=60
AI_IMPORT_HEURISTIC_HIGH_CONFIDENCE=0.82
AI_IMPORT_HEURISTIC_MEDIUM_CONFIDENCE=0.58
AI_CACHE_ENABLED=true
AI_CACHE_DEFAULT_TTL_SECONDS=600
AI_CACHE_FEATURE_AUDIT_INSIGHTS=true
AI_CACHE_FEATURE_COMMUNICATION_NOTIFICATIONS=true
AI_CACHE_FEATURE_RELEASE_COMPLIANCE=true
AI_CACHE_FEATURE_PAYMENT_RECONCILIATION=false
AI_CACHE_FEATURE_PAYMENT_NORMALIZATION=true
AI_CACHE_TTL_AUDIT_INSIGHTS=900
AI_CACHE_TTL_COMMUNICATION_NOTIFICATIONS=86400
AI_CACHE_TTL_RELEASE_COMPLIANCE=7200
AI_CACHE_TTL_PAYMENT_NORMALIZATION=1800
AI_RETRY_BACKOFF_SECONDS=0.3
AI_MAX_FALLBACK_ROUTES=1
AI_PERSIST_EXECUTION_EVENTS=false

AI_FEATURE_PAYMENT_RECONCILIATION=true
AI_FEATURE_PAYMENT_NORMALIZATION=true
AI_FEATURE_AUDIT_INSIGHTS=true
AI_FEATURE_RELEASE_COMPLIANCE=true
AI_FEATURE_REGRESSION_TESTS=true
AI_FEATURE_COMMUNICATION_NOTIFICATIONS=true

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
